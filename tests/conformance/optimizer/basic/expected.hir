Function main
  Block b0
    v0 = alloc number 'x'
    v1 = const number 10
    v2 = const number 20
    v3 = const number 3
    v4 = MUL number v2, v3
    v5 = ADD number v1, v4
    store v0, v5
    v6 = alloc number 'y'
    v7 = load number v0
    store v6, v7
    v8 = const bool False
    branch v8 ? b1 : b2
  Block b1
    v9 = load number v0
    v10 = intrinsic PRINT(v9)
    jump b3
  Block b2
    jump b3
  Block b3
    ret
